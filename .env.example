# Studio Agent — LLM provider API keys
# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit it.
# At least one provider must be set when using --mode=llm.

# Primary: Google AI Studio (Gemini Flash — 1500 req/day free, structured output)
# Get key: https://aistudio.google.com/api-keys
GEMINI_API_KEY=

# Fallback 1: Groq Cloud (Llama 3.3 70B — ultra-fast, generous free tier)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Fallback 2: OpenRouter (aggregator, has :free models)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Fallback 3: Cloudflare Workers AI (10k neuron/day free)
# Get key: https://dash.cloudflare.com/profile/api-tokens (Workers AI template)
# Account ID: from dashboard URL, e.g. dash.cloudflare.com/<ACCOUNT_ID>/home
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
